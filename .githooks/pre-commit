#!/bin/sh
# Ensure git hooks path is set (e.g. after clone without pnpm install)
root=$(git rev-parse --show-toplevel) || exit 1
cd "$root" && node scripts/setup-git-hooks.mjs || true
# Always stage version files if changed, so they're included in this commit
cd "$root" && node scripts/stage-version-files-if-changed.mjs || exit 1
exit 0
