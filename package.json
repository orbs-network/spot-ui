{
  "name": "spot-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "dev": "pnpm --filter web dev",
    "start": "pnpm --filter web start",
    "build": "pnpm build:spot-ui && pnpm build:liquidity-hub && pnpm build:spot-react && pnpm --filter web build",
    "build:spot-ui": "pnpm --filter @orbs-network/spot-ui build",
    "build:liquidity-hub": "pnpm --filter @orbs-network/liquidity-hub-sdk build",
    "build:spot-react": "pnpm --filter @orbs-network/spot-react build",
    "build:web": "pnpm --filter web build"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.2.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.1"
}
